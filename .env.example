# Скопіюйте у .env і змініть значення для локального запуску.
# У проді секрети подаються через Docker secrets / CI — див. README.

POSTGRES_USER=bola
POSTGRES_PASSWORD=change_me_db
POSTGRES_DB=bola

# Спільний секрет підпису JWT (auth + gateway)
JWT_SECRET=please_use_a_long_random_string_at_least_32_chars

# Секрет «довіреного» шляху між gateway і reports (заголовок X-Gateway-Token)
GATEWAY_INTERNAL_TOKEN=change_me_gateway_token

# vulnerable = BOLA: звіт видається лише за ID, org не перевіряється
# secure = перевірка org_id (з JWT через gateway) узгоджена з власником звіту
REPORTS_AUTHZ_MODE=vulnerable
